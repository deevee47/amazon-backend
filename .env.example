# PostgreSQL connection string from Neon dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/amazon_clone?sslmode=require

# HTTP port for the Express server (Next.js runs on 3000, use 3001)
PORT=3001

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
